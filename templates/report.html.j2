<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Facebook Monitor — {{ report.date }}</title>
  <style>
    body { font-family: system-ui, sans-serif; margin: 24px; color: #1a1a1a; }
    h1 { font-size: 1.35rem; }
    .meta { color: #555; font-size: 0.9rem; margin-bottom: 24px; }
    .card { border: 1px solid #e5e5e5; border-radius: 8px; padding: 16px; margin-bottom: 16px; }
    ul { margin: 0; padding-left: 18px; }
    .pill { display: inline-block; background: #f4f4f5; border-radius: 999px; padding: 2px 10px; font-size: 0.8rem; margin-right: 6px; }
  </style>
</head>
<body>
  <h1>Facebook Monitor</h1>
  <p class="meta">Date: <strong>{{ report.date }}</strong> · Posts tracked: <strong>{{ report.total_posts }}</strong></p>

  <div class="card">
    <h2 style="margin-top:0;font-size:1.1rem;">AI summary</h2>
    <p>{{ analysis.summary or "—" }}</p>
    {% if analysis.trends %}
      <p><strong>Trends</strong></p>
      <ul>
        {% for t in analysis.trends %}
          <li>{{ t }}</li>
        {% endfor %}
      </ul>
    {% endif %}
    {% if analysis.recommendations %}
      <p><strong>Recommendations</strong></p>
      <ul>
        {% for r in analysis.recommendations %}
          <li>{{ r }}</li>
        {% endfor %}
      </ul>
    {% endif %}
    {% if analysis.urgency_level %}
      <p><span class="pill">Urgency: {{ analysis.urgency_level }}</span></p>
    {% endif %}
  </div>

  {% if report.groups %}
    <div class="card">
      <h2 style="margin-top:0;font-size:1.1rem;">Groups</h2>
      <p>{% for g in report.groups %}<span class="pill">{{ g }}</span>{% endfor %}</p>
    </div>
  {% endif %}
</body>
</html>
