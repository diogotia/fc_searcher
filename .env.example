# Copy to .env and fill in values. Never commit .env.

# =============================================================================
# Agentic Facebook (opt-in — scripts/run_agentic/run_agentic_facebook_*.py)
# Separate from classic ENABLE_BROWSER_SEARCH_SYNC; uses same BROWSER_* queries.
# =============================================================================
ENABLE_AGENTIC_FACEBOOK_SYNC=false
# AGENTIC_FACEBOOK_OUTPUT_DIR=output/agentic_facebook
# AGENTIC_FACEBOOK_SOURCE=playwright_agentic

# =============================================================================
# Facebook Graph API (App Dashboard, long-lived token, group feed)
# Workflow: developers.facebook.com → App → tokens; see README for oauth scripts.
# =============================================================================
# FACEBOOK_OAUTH_SCOPES=public_profile,groups_access_member_info
FACEBOOK_SHORT_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
GRAPH_API_VERSION=v21.0
FACEBOOK_SYNC_MODE=groups
FACEBOOK_GROUP_IDS=
# Offline dev (no Meta calls): JSON shaped like Graph `/{group}/feed` → `{ "data": [ ... ] }`
# FACEBOOK_MOCK_FEED_JSON=./tests/fixtures/sample_group_feed.json

# =============================================================================
# Facebook web login (Playwright — optional auto-fill; prefer storage state over password)
# =============================================================================
FACEBOOK_WEB_LOGIN=
FACEBOOK_WEB_PASSWORD=
# PLAYWRIGHT_STORAGE_STATE_PATH=

# =============================================================================
# Classic Playwright browser group search (MCP /admin/browser-search-sync)
# — ENABLE_BROWSER_SEARCH_SYNC: distinct from agentic scripts when both are documented.
# — BROWSER_SEARCH_QUERY: first comma segment → /search/groups?q= discovery.
# — BROWSER_IN_GROUP_SEARCH_QUERY: comma tokens; in-group /groups/.../search/?q= (see CLI --in-group-exact-keywords).
# — BROWSER_GROUP_SCAN_LIMIT: max extra groups from discovery (1..100); seeds not counted.
# — BROWSER_SEED_GROUP_URLS: scanned before discovery merge.
# =============================================================================
ENABLE_BROWSER_SEARCH_SYNC=false
BROWSER_HEADLESS=false
BROWSER_SEARCH_QUERY=job
BROWSER_IN_GROUP_SEARCH_QUERY=
# Optional CSV: when set with run_agentic_facebook_exact_posts.py, the scraped post body
# must contain at least one of these tokens (case-insensitive substring OR-filter). Pair with
# BROWSER_GLOBAL_MESSAGE_CONTAINS (or --global-message-contains) for the mandatory AND phrase
# (e.g. "ищу работу"). Empty = no OR-filter.
BROWSER_IN_GROUP_SEARCH_IN_POST=
# Mandatory AND substring on post body for exact-posts agentic flow (case-insensitive). Empty = no AND filter.
# CLI --global-message-contains overrides when provided.
BROWSER_GLOBAL_MESSAGE_CONTAINS=
BROWSER_GROUP_SCAN_LIMIT=20
BROWSER_POST_LIMIT_PER_GROUP=25
BROWSER_SEARCH_TIMEOUT_SECONDS=180
BROWSER_SEED_GROUP_URLS=

# =============================================================================
# Browser post publication filters (browser sync + reports; year/date from DOM or created_time)
# =============================================================================
BROWSER_POST_PUBLICATION_YEAR=
# BROWSER_POST_PUBLICATION_YEAR=auto
BROWSER_POST_PUBLICATION_MONTH=
BROWSER_POST_PUBLICATION_DAY=
BROWSER_POST_PUBLICATION_KEEP_UNKNOWN_YEAR=false

# Experimental: Claude vision on Meta checkpoints (needs ANTHROPIC_API_KEY)
# ENABLE_BROWSER_META_CHALLENGE_VISION=false

# =============================================================================
# Anthropic (Claude — prompts/reports; optional Meta challenge vision)
# =============================================================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# SMTP (e.g. Gmail app password — HTML/CSV report email)
# Optional: email a Playwright HTML export:
#   .venv/bin/python scripts/send_browser_search_report_email.py --folder search_20260426T113551Z
# =============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL=
REPORT_EMAIL_CC=

# =============================================================================
# Database (SQLite path relative to cwd for sqlite:///./...)
# Docker: sqlite:////app/data/facebook_monitor.db
# =============================================================================
DATABASE_URL=sqlite:///./data/facebook_monitor.db

# =============================================================================
# Meta webhook (GET verify + POST signature)
# =============================================================================
WEBHOOK_VERIFY_TOKEN=

# =============================================================================
# Application — timezone, logging, cron, monitor keywords, reports directory
# =============================================================================
TIMEZONE=UTC
LOG_LEVEL=INFO
# LOG_JSON=0
REPORT_CRON=0 7 * * *
SYNC_CRON=15 */6 * * *
ENABLE_SCHEDULER=true
MONITOR_KEYWORDS=Работа в Германии,Вакансии в Германии,Работа в Германии для русских
REPORTS_DIR=/app/reports

# =============================================================================
# Admin API (/admin/* triggers — required in production)
# =============================================================================
ADMIN_TOKEN=
# Unauthenticated GET /search over the DB (trusted networks only)
ENABLE_PUBLIC_POST_SEARCH=false

# =============================================================================
# Postgres (docker-compose.prod.yml only)
# =============================================================================
POSTGRES_USER=monitor
POSTGRES_PASSWORD=
POSTGRES_DB=monitor

# =============================================================================
# Grafana (optional monitoring profile)
# =============================================================================
GRAFANA_ADMIN_PASSWORD=
