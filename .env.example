# Copy to .env and fill in values. Never commit .env.

# --- Facebook / Meta (workflow) ---------------------------------------------
# 1) developers.facebook.com → Create App (e.g. Business)
# 2) App Review → Permissions: request what Meta currently allows for your use case
#    (names change; e.g. groups_access_member_info — confirm in docs for GRAPH_API_VERSION)
# 3) Short-lived *user* token: Graph API Explorer, OR scripts/oauth_facebook_user_token.py
#    (Facebook Login + redirect URI in app settings). Optional default scopes for the latter:
# Comma-separated scopes for scripts/oauth_facebook_user_token.py (and oauth_*_groups.sh)
# FACEBOOK_OAUTH_SCOPES=public_profile,groups_access_member_info
# 4) Long-lived exchange — paste Graph API Explorer *short* user token (required to run
#    scripts/exchange_user_long_lived_token.py; then copy result into FACEBOOK_ACCESS_TOKEN):
FACEBOOK_SHORT_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# 5) After exchange + feed test (scripts/test_facebook_group_feed.py), use long-lived token:
FACEBOOK_ACCESS_TOKEN=
GRAPH_API_VERSION=v21.0
# groups = use FACEBOOK_GROUP_IDS; me = sync GET /me/feed only (FACEBOOK_GROUP_IDS may be empty)
FACEBOOK_SYNC_MODE=groups
# Numeric group ids only (digits), comma-separated — not a slug or full URL
FACEBOOK_GROUP_IDS=
# Offline dev (no Meta calls): JSON file shaped like Graph `/{group}/feed` → `{ "data": [ ... ] }`
# FACEBOOK_MOCK_FEED_JSON=./tests/fixtures/sample_group_feed.json

# Playwright browser group search (MCP tool facebook_browser_search_sync / POST /admin/browser-search-sync)
# ENABLE_BROWSER_SEARCH_SYNC=false
# BROWSER_SEARCH_QUERY=job
# Comma-separated in-group tokens: each run uses "<BROWSER_SEARCH_QUERY> <token>" per phase. Empty = use BROWSER_SEARCH_QUERY only.
# BROWSER_IN_GROUP_SEARCH_QUERY=малярные работы,монтаж гипсокартона
# Max groups from Facebook /search/groups per run (1..100). Seed URLs in BROWSER_SEED_GROUP_URLS are always all scanned, then up to this many discovery groups are added.
# BROWSER_GROUP_SCAN_LIMIT=20
# BROWSER_GROUP_SCAN_LIMIT=100
# BROWSER_POST_LIMIT_PER_GROUP=25
# Optional: only keep posts whose inferred publication year matches (browser sync + daily CSV/HTML report).
# Inferred from created_time or the post header (text before "·") for Russian/ISO dates. Use "auto" for current UTC year.
# Posts with no parsable year are dropped unless:
# BROWSER_POST_PUBLICATION_KEEP_UNKNOWN_YEAR=true
# BROWSER_POST_PUBLICATION_YEAR=2026
# BROWSER_POST_PUBLICATION_YEAR=auto
# Optional with YEAR: minimum publication date (inclusive, UTC calendar). Example 27.04.2026:
# BROWSER_POST_PUBLICATION_MONTH=4
# BROWSER_POST_PUBLICATION_DAY=27
# With MONTH set, posts must be on or after that date (header Russian/ISO date, else created_time).
# If MONTH is set and DAY is omitted, the cutoff is the first day of that month.
# BROWSER_HEADLESS=false
# BROWSER_SEARCH_TIMEOUT_SECONDS=180
# Comma-separated group URLs or numeric ids opened first (before group search), e.g.:
# BROWSER_SEED_GROUP_URLS=https://www.facebook.com/groups/934750153812574
# PLAYWRIGHT_STORAGE_STATE_PATH=
# Optional: auto-fill the Facebook web login form before manual wait (same Playwright session). Storing
# a real password in .env is risky — prefer PLAYWRIGHT_STORAGE_STATE_PATH or manual login when possible.
# FACEBOOK_WEB_LOGIN=
# FACEBOOK_WEB_PASSWORD=
# Experimental: Claude vision suggests ArrowRight count + Submit on Meta visual checkpoints (needs ANTHROPIC_API_KEY)
# ENABLE_BROWSER_META_CHALLENGE_VISION=false

# Separate opt-in agentic Facebook flow (script/admin/MCP). Defaults off and does not change
# the classic Playwright browser sync above.
# ENABLE_AGENTIC_FACEBOOK_SYNC=false
# AGENTIC_FACEBOOK_OUTPUT_DIR=output/agentic_facebook
# AGENTIC_FACEBOOK_SOURCE=playwright_agentic

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL=
REPORT_EMAIL_CC=
# Optional: email a specific Playwright HTML export (not the daily CSV):
#   .venv/bin/python scripts/send_browser_search_report_email.py --folder search_20260426T113551Z
#   ./scripts/admin_request.sh report-browser-html search_20260426T113551Z
# Docker: mount host ``./report`` so ``report/search_*`` exists at the same path as on the host.

# Meta webhook (GET verify + POST signature)
WEBHOOK_VERIFY_TOKEN=

# App
# Local / MCP: relative to process cwd (open project from repo root). Docker: sqlite:////app/data/facebook_monitor.db
DATABASE_URL=sqlite:///./data/facebook_monitor.db
TIMEZONE=UTC
LOG_LEVEL=INFO
# Set to 1 for JSON log lines (e.g. production log aggregation)
# LOG_JSON=0
REPORT_CRON=0 7 * * *
SYNC_CRON=15 */6 * * *
ENABLE_SCHEDULER=true
# Comma-separated; used in Claude prompts / reports (e.g. job search in Germany)
MONITOR_KEYWORDS=Работа в Германии,Вакансии в Германии,Работа в Германии для русских
# Daily report CSVs: report_<YYYY-MM-DD>_<UTCstamp>.csv plus _phones.csv / _emails.csv (unique per run)
REPORTS_DIR=/app/reports

# Protect /admin/* triggers (required in production)
ADMIN_TOKEN=
# Unauthenticated GET /search over the DB (default off; use only on trusted networks / behind auth)
ENABLE_PUBLIC_POST_SEARCH=false

# Postgres (only when using docker-compose.prod.yml)
POSTGRES_USER=monitor
POSTGRES_PASSWORD=
POSTGRES_DB=monitor

# Grafana (optional monitoring profile)
GRAFANA_ADMIN_PASSWORD=
